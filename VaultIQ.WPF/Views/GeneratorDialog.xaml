<Window
    x:Class="VaultIQ.WPF.Views.GeneratorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VaultIQ — Générateur de mots de passe"
    Width="420"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Midnight" Color="#070E1C" />
        <SolidColorBrush x:Key="Mid" Color="#132944" />
        <SolidColorBrush x:Key="Panel" Color="#0F2035" />
        <SolidColorBrush x:Key="Blue" Color="#185FA5" />
        <SolidColorBrush x:Key="Accent" Color="#378ADD" />
        <SolidColorBrush x:Key="Teal2" Color="#12D68C" />
        <SolidColorBrush x:Key="Border1" Color="#26378ADD" />
        <SolidColorBrush x:Key="Border2" Color="#47378ADD" />
        <SolidColorBrush x:Key="Text1" Color="#D4E4F7" />
        <SolidColorBrush x:Key="Text2" Color="#7BA3C8" />
        <SolidColorBrush x:Key="Text3" Color="#3D6080" />
        <SolidColorBrush x:Key="Green" Color="#22C55E" />
        <SolidColorBrush x:Key="Amber" Color="#F59E0B" />
        <SolidColorBrush x:Key="Red" Color="#EF4444" />

        <!--  Section header  -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Text3}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!--  Option row label  -->
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  Icon button  -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Mid}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Button cancel  -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A378ADD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E72BB" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Teal copy button  -->
        <Style
            x:Key="BtnTeal"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="#1F1D9E75" />
            <Setter Property="Foreground" Value="{StaticResource Teal2}" />
            <Setter Property="BorderBrush" Value="#591D9E75" />
        </Style>
    </Window.Resources>

    <Border
        Background="{StaticResource Midnight}"
        BorderBrush="{StaticResource Border2}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="60"
                Opacity="0.8"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  preview  -->
                <RowDefinition Height="Auto" />
                <!--  options  -->
                <RowDefinition Height="Auto" />
                <!--  history  -->
                <RowDefinition Height="Auto" />
                <!--  buttons  -->
            </Grid.RowDefinitions>

            <!--  ══ HEADER ══════════════════════════════════════  -->
            <Border
                Grid.Row="0"
                Padding="18,14"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#185FA5" />
                        <GradientStop Offset="1" Color="#0C3360" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="🎲 Générateur de mots de passe" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="11"
                        Foreground="#8CFFFFFF"
                        Text="CSPRNG · Entropie calculée en temps réel" />
                </StackPanel>
            </Border>

            <!--  ══ PREVIEW CARD ══════════════════════════════════  -->
            <Border
                Grid.Row="1"
                Padding="18,14"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,0,0,1">
                <StackPanel>
                    <!--  Generated password display  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="14,10"
                        Height="150"
                        Background="{StaticResource Mid}"
                        BorderBrush="{StaticResource Border2}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <DockPanel>
                            <StackPanel
                                Margin="10,0,0,0"
                                DockPanel.Dock="Right"
                                Orientation="Horizontal">
                                <Button
                                    x:Name="RegenerateBtn"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,6,0"
                                    Click="RegenerateBtn_Click"
                                    Content="↻"
                                    FontSize="16"
                                    Style="{StaticResource IconBtn}"
                                    ToolTip="Régénérer (espace)" />
                                <Button
                                    x:Name="CopyBtn"
                                    Height="32"
                                    Padding="10,0"
                                    Click="CopyBtn_Click"
                                    Content="📋 Copier"
                                    FontSize="11"
                                    Style="{StaticResource BtnTeal}" />
                            </StackPanel>
                            <TextBlock
                                x:Name="PreviewText"
                                VerticalAlignment="Center"
                                FontFamily="Consolas"
                                FontSize="15"
                                Foreground="{StaticResource Accent}"
                                TextWrapping="Wrap" />
                        </DockPanel>
                    </Border>

                    <!--  Strength bar + badges  -->
                    <Grid
                        x:Name="StrengthContainer"
                        Height="5"
                        Margin="0,0,0,6">
                        <Border Background="{StaticResource Panel}" CornerRadius="3" />
                        <Border
                            x:Name="StrengthFill"
                            Width="0"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Green}"
                            CornerRadius="3" />
                    </Grid>
                    <DockPanel>
                        <TextBlock
                            x:Name="StrengthLabel"
                            DockPanel.Dock="Left"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{StaticResource Green}" />
                        <!--  Entropy badge  -->
                        <Border
                            Padding="8,2"
                            HorizontalAlignment="Right"
                            Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Border1}"
                            BorderThickness="1"
                            CornerRadius="8"
                            DockPanel.Dock="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{StaticResource Amber}"
                                    Text="⚡ " />
                                <TextBlock
                                    x:Name="EntropyBadge"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    Foreground="{StaticResource Amber}" />
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!--  ══ OPTIONS ══════════════════════════════════════  -->
            <StackPanel Grid.Row="2" Margin="18,14,18,14">

                <!--  LENGTH slider  -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="OPTIONS" />
                <Border
                    Margin="0,0,0,10"
                    Padding="14,10"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <!--  Length  -->
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock
                                Width="80"
                                DockPanel.Dock="Left"
                                Style="{StaticResource OptionLabel}"
                                Text="Longueur" />
                            <Border
                                MinWidth="38"
                                Padding="8,2"
                                HorizontalAlignment="Right"
                                Background="{StaticResource Mid}"
                                BorderBrush="{StaticResource Border2}"
                                BorderThickness="1"
                                CornerRadius="5"
                                DockPanel.Dock="Right">
                                <TextBlock
                                    x:Name="LengthValue"
                                    HorizontalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Foreground="{StaticResource Accent}"
                                    Text="20" />
                            </Border>
                            <Slider
                                x:Name="LengthSlider"
                                Margin="0,0,8,0"
                                Foreground="{StaticResource Accent}"
                                IsSnapToTickEnabled="True"
                                Maximum="128"
                                Minimum="4"
                                TickFrequency="1"
                                Value="20" />
                        </DockPanel>

                        <!--  Separator  -->
                        <Rectangle
                            Height="1"
                            Margin="0,0,0,10"
                            Fill="{StaticResource Border1}" />

                        <!--  Character types  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkUppercase"
                                        Margin="0,0,8,0"
                                        IsChecked="True" />
                                    <TextBlock Style="{StaticResource OptionLabel}" Text="Majuscules" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="  A–Z" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkLowercase"
                                        Margin="0,0,8,0"
                                        IsChecked="True" />
                                    <TextBlock Style="{StaticResource OptionLabel}" Text="Minuscules" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="  a–z" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkDigits"
                                        Margin="0,0,8,0"
                                        IsChecked="True" />
                                    <TextBlock Style="{StaticResource OptionLabel}" Text="Chiffres" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="  0–9" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkSymbols"
                                        Margin="0,0,8,0"
                                        IsChecked="False" />
                                    <TextBlock Style="{StaticResource OptionLabel}" Text="Symboles" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="  !@#…" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!--  No ambiguous  -->
                        <StackPanel Orientation="Horizontal">
                            <CheckBox
                                x:Name="ChkNoAmbiguous"
                                Margin="0,0,8,0"
                                IsChecked="True" />
                            <TextBlock Style="{StaticResource OptionLabel}">
                                Exclure les caractères ambigus<Run
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Foreground="{StaticResource Text3}">
                                    0 O 1 l I
                                </Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  SECURITY INFO  -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="SÉCURITÉ" />
                <Border
                    Padding="14,10"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Générateur" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Teal2}"
                                Text="CSPRNG — RandomNumberGenerator.Fill()" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Biais modulo" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Teal2}"
                                Text="Éliminé — méthode de rejet" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Entropie min." />
                            <TextBlock
                                x:Name="MinEntropyInfo"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Text2}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  HISTORY (last 5)  -->
                <TextBlock
                    Margin="0,14,0,8"
                    Style="{StaticResource SectionLabel}"
                    Text="HISTORIQUE SESSION" />
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="{StaticResource Panel}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="5">
                                <DockPanel>
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Click="HistoryCopy_Click"
                                        Content="📋"
                                        DockPanel.Dock="Right"
                                        FontSize="11"
                                        Style="{StaticResource IconBtn}"
                                        Tag="{Binding}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="{Binding}"
                                        TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <!--  ══ BUTTONS ══════════════════════════════════════  -->
            <Border
                Grid.Row="4"
                Padding="18,12"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="False">
                    <TextBlock
                        x:Name="CopiedFeedback"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontSize="11"
                        Foreground="{StaticResource Teal2}"
                        Text="✓ Copié !"
                        Visibility="Collapsed" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="CloseBtn_Click"
                            Content="Fermer"
                            Style="{StaticResource BtnCancel}" />
                        <Button
                            x:Name="UseBtn"
                            Click="UseBtn_Click"
                            Content="✓ Utiliser ce mot de passe"
                            Style="{StaticResource BtnPrimary}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
