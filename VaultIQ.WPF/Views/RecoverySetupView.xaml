<Window
    x:Class="VaultIQ.Views.RecoverySetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VaultIQ — Configuration de la récupération"
    Width="420"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Midnight" Color="#070E1C" />
        <SolidColorBrush x:Key="Panel" Color="#0F2035" />
        <SolidColorBrush x:Key="Blue" Color="#185FA5" />
        <SolidColorBrush x:Key="Accent" Color="#378ADD" />
        <SolidColorBrush x:Key="Border1" Color="#26378ADD" />
        <SolidColorBrush x:Key="Border2" Color="#47378ADD" />
        <SolidColorBrush x:Key="Text1" Color="#D4E4F7" />
        <SolidColorBrush x:Key="Text2" Color="#7BA3C8" />
        <SolidColorBrush x:Key="Text3" Color="#3D6080" />
        <SolidColorBrush x:Key="Teal2" Color="#12D68C" />

        <Style x:Key="StepDone" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{StaticResource Teal2}" />
        </Style>
        <Style x:Key="StepActive" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{StaticResource Blue}" />
        </Style>
        <Style x:Key="StepPending" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E72BB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border
        Background="{StaticResource Midnight}"
        BorderBrush="{StaticResource Border2}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="60"
                Opacity="0.8"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  steps bar  -->
                <RowDefinition Height="Auto" />
                <!--  body  -->
                <RowDefinition Height="Auto" />
                <!--  buttons  -->
            </Grid.RowDefinitions>

            <!--  ── HEADER ───────────────────────────────────  -->
            <Border
                Grid.Row="0"
                Padding="18,14"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#185FA5" />
                        <GradientStop Offset="1" Color="#0C3360" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="🛡️ Configuration de la récupération" />
                    <TextBlock
                        x:Name="StepSubtitle"
                        Margin="0,3,0,0"
                        FontSize="11"
                        Foreground="#8CFFFFFF" />
                </StackPanel>
            </Border>

            <!--  ── STEP PROGRESS BAR ────────────────────────  -->
            <Border
                Grid.Row="1"
                Padding="0,10"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,0,0,1">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <!--  Step 1  -->
                    <Border x:Name="Step1Border" Style="{StaticResource StepDone}">
                        <TextBlock
                            x:Name="Step1Text"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="#070E1C"
                            Text="✓" />
                    </Border>
                    <!--  Line 1-2  -->
                    <Border
                        x:Name="Line12"
                        Width="22"
                        Height="2"
                        VerticalAlignment="Center"
                        Background="{StaticResource Teal2}" />
                    <!--  Step 2  -->
                    <Border x:Name="Step2Border" Style="{StaticResource StepActive}">
                        <TextBlock
                            x:Name="Step2Text"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="2" />
                    </Border>
                    <!--  Line 2-3  -->
                    <Border
                        x:Name="Line23"
                        Width="22"
                        Height="2"
                        VerticalAlignment="Center"
                        Background="{StaticResource Border1}" />
                    <!--  Step 3  -->
                    <Border x:Name="Step3Border" Style="{StaticResource StepPending}">
                        <TextBlock
                            x:Name="Step3Text"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{StaticResource Text3}"
                            Text="3" />
                    </Border>
                    <!--  Line 3-4  -->
                    <Border
                        x:Name="Line34"
                        Width="22"
                        Height="2"
                        VerticalAlignment="Center"
                        Background="{StaticResource Border1}" />
                    <!--  Step 4  -->
                    <Border x:Name="Step4Border" Style="{StaticResource StepPending}">
                        <TextBlock
                            x:Name="Step4Text"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{StaticResource Text3}"
                            Text="4" />
                    </Border>
                </StackPanel>
            </Border>

            <!--  ── BODY (step content swapped in code-behind) ──  -->
            <StackPanel
                x:Name="StepBody"
                Grid.Row="2"
                Margin="18">

                <!--  Section label  -->
                <TextBlock
                    x:Name="SectionLabel"
                    Margin="0,0,0,8"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Text3}" />

                <!--  Description  -->
                <TextBlock
                    x:Name="DescText"
                    Margin="0,0,0,14"
                    FontSize="12"
                    Foreground="{StaticResource Text2}"
                    LineHeight="19"
                    TextWrapping="Wrap" />

                <!--  Country code  -->
                <StackPanel x:Name="CountryRow" Margin="0,0,0,14">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource Text2}"
                        Text="Indicatif pays" />
                    <ComboBox
                        x:Name="CountryCombo"
                        Height="36"
                        Padding="12,0"
                        Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource Border1}"
                        FontSize="12"
                        Foreground="{StaticResource Text2}"
                        SelectionChanged="CountryCombo_SelectionChanged">
                        <ComboBoxItem>🇩🇿 Algérie (+213)</ComboBoxItem>
                        <ComboBoxItem>🇲🇦 Maroc (+212)</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">🇫🇷 France (+33)</ComboBoxItem>
                        <ComboBoxItem>🇹🇳 Tunisie (+216)</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!--  Phone number  -->
                <StackPanel x:Name="PhoneRow" Margin="0,0,0,14">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource Text2}"
                        Text="Numéro de téléphone" />
                    <Grid>
                        <TextBox
                            x:Name="PhoneBox"
                            Style="{StaticResource FormInput}"
                            TextChanged="PhoneBox_TextChanged" />
                        <TextBlock
                            Margin="13,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="13"
                            Foreground="{StaticResource Text3}"
                            IsHitTestVisible="False"
                            Text="Ex: 0612345678">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=PhoneBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock
                        x:Name="PhoneValidText"
                        Margin="0,5,0,0"
                        FontSize="10"
                        Foreground="{StaticResource Teal2}"
                        Visibility="Collapsed" />
                </StackPanel>

                <!--  Security info  -->
                <Border
                    Padding="12,9"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="7">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Affiché après config." />
                            <TextBlock
                                x:Name="MaskedPhone"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Text2}"
                                Text="+33 06** **** 78" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Stockage" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Teal2}"
                                Text="Hash PBKDF2 100k iter" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Jamais transmis" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Teal2}"
                                Text="Stocké localement uniquement" />
                        </DockPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!--  ── BUTTONS ───────────────────────────────────  -->
            <Border
                Grid.Row="3"
                Padding="18,12"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="False">
                    <Button
                        Click="BackBtn_Click"
                        Content="Retour"
                        DockPanel.Dock="Left"
                        Style="{StaticResource BtnCancel}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="SkipBtn_Click"
                            Content="Passer"
                            Style="{StaticResource BtnCancel}" />
                        <Button
                            x:Name="NextBtn"
                            Click="NextBtn_Click"
                            Content="Suivant →"
                            Style="{StaticResource BtnPrimary}" />
                    </StackPanel>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
