<Window
    x:Class="VaultIQ.WPF.Views.NewDatabaseDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VaultIQ — Nouvelle base de données"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Midnight" Color="#070E1C" />
        <SolidColorBrush x:Key="Panel" Color="#0F2035" />
        <SolidColorBrush x:Key="Blue" Color="#185FA5" />
        <SolidColorBrush x:Key="Accent" Color="#378ADD" />
        <SolidColorBrush x:Key="Border1" Color="#26378ADD" />
        <SolidColorBrush x:Key="Border2" Color="#47378ADD" />
        <SolidColorBrush x:Key="Text1" Color="#D4E4F7" />
        <SolidColorBrush x:Key="Text2" Color="#7BA3C8" />
        <SolidColorBrush x:Key="Text3" Color="#3D6080" />
        <SolidColorBrush x:Key="Green" Color="#22C55E" />
        <SolidColorBrush x:Key="Amber" Color="#F59E0B" />
        <SolidColorBrush x:Key="Red" Color="#EF4444" />

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,0,36,0" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormPasswordInput" TargetType="PasswordBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,0,36,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E72BB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border
        Background="{StaticResource Midnight}"
        BorderBrush="{StaticResource Border2}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="60"
                Opacity="0.8"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ── HEADER ───────────────────────────────────  -->
            <Border
                Grid.Row="0"
                Padding="18,14"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#185FA5" />
                        <GradientStop Offset="1" Color="#0C3360" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="✨ Nouvelle base de données" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="11"
                        Foreground="#8CFFFFFF"
                        Text="Créer et chiffrer un nouveau fichier .viq" />
                </StackPanel>
            </Border>

            <!--  ── BODY ─────────────────────────────────────  -->
            <StackPanel Grid.Row="1" Margin="18">

                <!--  Database name  -->
                <StackPanel Margin="0,0,0,14">
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock
                            DockPanel.Dock="Left"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{StaticResource Text2}"
                            Text="Nom de la base" />
                        <TextBlock
                            Margin="5,0,0,0"
                            DockPanel.Dock="Right"
                            FontSize="10"
                            Foreground="{StaticResource Text3}"
                            Text="affiché en clair dans le fichier" />
                    </DockPanel>
                    <Grid>
                        <TextBox
                            x:Name="DbNameBox"
                            Padding="12,0"
                            Style="{StaticResource FormInput}"
                            Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Margin="13,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource Text3}"
                            IsHitTestVisible="False"
                            Text="Ex: Travail, Perso, Famille…">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=DbNameBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!--  Master password  -->
                <StackPanel Margin="0,0,0,14">
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock
                            DockPanel.Dock="Left"
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{StaticResource Text2}"
                            Text="Mot de passe principal" />
                        <TextBlock
                            Margin="5,0,0,0"
                            DockPanel.Dock="Right"
                            FontSize="10"
                            Foreground="{StaticResource Text3}"
                            Text="min. 4 caractères" />
                    </DockPanel>
                    <Grid>
                        <PasswordBox
                            x:Name="MasterPasswordBox"
                            PasswordChanged="MasterPasswordBox_PasswordChanged"
                            Style="{StaticResource FormPasswordInput}" />
                        <Button
                            x:Name="EyeBtn1"
                            Width="28"
                            Height="28"
                            Margin="0,0,5,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="EyeBtn1_Click"
                            Content="👁"
                            Cursor="Hand"
                            Foreground="{StaticResource Text3}" />
                    </Grid>
                    <!--  Strength bar  -->
                    <Grid
                        x:Name="StrengthBarContainer"
                        Height="4"
                        Margin="0,6,0,0">
                        <Border Background="{StaticResource Panel}" CornerRadius="2" />
                        <Border
                            x:Name="StrengthBarFill"
                            Width="0"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Green}"
                            CornerRadius="2" />
                    </Grid>
                    <DockPanel Margin="0,3,0,0">
                        <TextBlock
                            x:Name="StrengthLabel"
                            FontSize="10"
                            Foreground="{StaticResource Green}" />
                        <TextBlock
                            x:Name="EntropyLabel"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            FontSize="10"
                            Foreground="{StaticResource Text3}" />
                    </DockPanel>
                </StackPanel>

                <!--  Confirm password  -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource Text2}"
                        Text="Confirmer le mot de passe" />
                    <Grid>
                        <PasswordBox
                            x:Name="ConfirmPasswordBox"
                            PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                            Style="{StaticResource FormPasswordInput}" />
                        <TextBlock
                            x:Name="ConfirmMatchIcon"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{StaticResource Green}"
                            Text="✓"
                            Visibility="Collapsed" />
                    </Grid>
                    <TextBlock
                        x:Name="ConfirmErrorText"
                        Margin="0,4,0,0"
                        FontSize="10"
                        Foreground="{StaticResource Red}"
                        Visibility="Collapsed" />
                </StackPanel>

                <!--  File path  -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource Text2}"
                        Text="Emplacement du fichier" />
                    <DockPanel>
                        <Button
                            Margin="6,0,0,0"
                            Padding="10,0"
                            Click="BrowseBtn_Click"
                            Content="Parcourir…"
                            DockPanel.Dock="Right"
                            FontSize="11"
                            Style="{StaticResource BtnCancel}" />
                        <TextBox
                            x:Name="FilePathBox"
                            Padding="12,0"
                            FontSize="11"
                            Style="{StaticResource FormInput}"
                            Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </StackPanel>

                <!--  Options  -->
                <StackPanel Margin="0,0,0,4">
                    <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                        <CheckBox
                            x:Name="PinChk"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding EnablePin}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{StaticResource Text3}"
                            Text="Activer un code PIN pour l'accès rapide (optionnel)" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox
                            x:Name="RecoveryChk"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding EnableRecovery}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{StaticResource Text3}"
                            Text="Configurer la récupération de compte après création" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!--  ── BUTTONS ───────────────────────────────────  -->
            <Border
                Grid.Row="2"
                Padding="18,12"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="False">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontSize="11"
                        Foreground="{StaticResource Text3}"
                        Text="Le premier groupe « Général » sera créé automatiquement." />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="CancelBtn_Click"
                            Content="Annuler"
                            Style="{StaticResource BtnCancel}" />
                        <Button
                            Click="CreateBtn_Click"
                            Content="✨ Créer"
                            IsDefault="True"
                            Style="{StaticResource BtnPrimary}" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>