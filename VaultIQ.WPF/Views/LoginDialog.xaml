<Window
    x:Class="VaultIQ.WPF.Views.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VaultIQ — Authentification"
    Width="400"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Midnight" Color="#070E1C" />
        <SolidColorBrush x:Key="Mid" Color="#132944" />
        <SolidColorBrush x:Key="Panel" Color="#0F2035" />
        <SolidColorBrush x:Key="Blue" Color="#185FA5" />
        <SolidColorBrush x:Key="Accent" Color="#378ADD" />
        <SolidColorBrush x:Key="Teal2" Color="#12D68C" />
        <SolidColorBrush x:Key="Border1" Color="#26378ADD" />
        <SolidColorBrush x:Key="Border2" Color="#47378ADD" />
        <SolidColorBrush x:Key="Text1" Color="#D4E4F7" />
        <SolidColorBrush x:Key="Text2" Color="#7BA3C8" />
        <SolidColorBrush x:Key="Text3" Color="#3D6080" />

        <!--  TextBox style  -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,0,36,0" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  PasswordBox style  -->
        <Style x:Key="FormPasswordInput" TargetType="PasswordBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Padding" Value="12,0,36,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Button cancel  -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Button primary  -->
        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E72BB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!--  Drop shadow frame  -->
    <Border
        Background="{StaticResource Midnight}"
        BorderBrush="{StaticResource Border2}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="60"
                Opacity="0.8"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  body  -->
                <RowDefinition Height="Auto" />
                <!--  buttons  -->
            </Grid.RowDefinitions>

            <!--  ── HEADER ───────────────────────────────────  -->
            <Border
                Grid.Row="0"
                Padding="18,14"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#185FA5" />
                        <GradientStop Offset="1" Color="#0C3360" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="🔐 Authentification" />
                    <TextBlock
                        x:Name="SubtitleText"
                        Margin="0,3,0,0"
                        FontSize="11"
                        Foreground="#8CFFFFFF" />
                </StackPanel>
            </Border>

            <!--  ── BODY ─────────────────────────────────────  -->
            <StackPanel Grid.Row="1" Margin="18">

                <!--  Metadata card  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="12,12,14,12"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <!--  Icon + name row  -->
                        <DockPanel Margin="0,0,0,10">
                            <Border
                                Width="38"
                                Height="38"
                                Margin="0,0,10,0"
                                Background="{StaticResource Mid}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="8"
                                DockPanel.Dock="Left">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Text="🏦" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    x:Name="DbNameText"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Foreground="{StaticResource Text1}" />
                                <TextBlock
                                    x:Name="DbSubText"
                                    Margin="0,2,0,0"
                                    FontSize="10"
                                    Foreground="{StaticResource Text3}" />
                            </StackPanel>
                        </DockPanel>
                        <!--  Stats grid  -->
                        <UniformGrid Columns="4" Rows="1">
                            <Border
                                Margin="0,0,3,0"
                                Padding="8,6"
                                Background="{StaticResource Midnight}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock
                                        x:Name="StatEntries"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Accent}" />
                                    <TextBlock
                                        Margin="0,1,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="9"
                                        Foreground="{StaticResource Text3}"
                                        Text="Entrées" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="3,0"
                                Padding="8,6"
                                Background="{StaticResource Midnight}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock
                                        x:Name="StatGroups"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Accent}" />
                                    <TextBlock
                                        Margin="0,1,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="9"
                                        Foreground="{StaticResource Text3}"
                                        Text="Groupes" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="3,0"
                                Padding="8,6"
                                Background="{StaticResource Midnight}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock
                                        x:Name="StatModified"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Accent}" />
                                    <TextBlock
                                        Margin="0,1,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="9"
                                        Foreground="{StaticResource Text3}"
                                        Text="Modifié" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="3,0,0,0"
                                Padding="8,6"
                                Background="{StaticResource Midnight}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock
                                        x:Name="StatRecovery"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Teal2}" />
                                    <TextBlock
                                        Margin="0,1,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="9"
                                        Foreground="{StaticResource Text3}"
                                        Text="Récupération" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!--  Password field  -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource Text2}"
                        Text="Mot de passe principal" />
                    <Grid>
                        <PasswordBox
                            x:Name="PasswordBox"
                            KeyDown="PasswordBox_KeyDown"
                            Style="{StaticResource FormPasswordInput}" />
                        <TextBox
                            x:Name="PasswordClearBox"
                            FontFamily="Consolas"
                            Style="{StaticResource FormInput}"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="EyeBtn"
                            Width="28"
                            Height="28"
                            Margin="0,0,5,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="EyeBtn_Click"
                            Content="👁"
                            Cursor="Hand"
                            Foreground="{StaticResource Text3}" />
                    </Grid>
                </StackPanel>

                <!--  Show password checkbox  -->
                <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                    <CheckBox
                        x:Name="ShowPasswordChk"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Checked="ShowPasswordChk_Changed"
                        Unchecked="ShowPasswordChk_Changed" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{StaticResource Text3}"
                        Text="Afficher le mot de passe" />
                </StackPanel>

                <!--  Security info  -->
                <Border
                    Padding="12,9"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="7">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Chiffrement" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Text2}"
                                Text="AES-256-CBC" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Itérations PBKDF2" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Text2}"
                                Text="150 000" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Intégrité" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Teal2}"
                                Text="HMAC-SHA256 ✓" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="10"
                                Foreground="{StaticResource Text3}"
                                Text="Format" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontFamily="Consolas"
                                FontSize="10"
                                Foreground="{StaticResource Text2}"
                                Text=".viq v1.0" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  Error message  -->
                <TextBlock
                    x:Name="ErrorText"
                    Margin="0,10,0,0"
                    FontSize="11"
                    Foreground="#EF4444"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>

            <!--  ── BUTTONS ───────────────────────────────────  -->
            <Border
                Grid.Row="2"
                Padding="18,12"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="False">
                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ForgotBtn_Click"
                        Content="Mot de passe oublié ?"
                        Cursor="Hand"
                        DockPanel.Dock="Left"
                        FontSize="11"
                        Foreground="{StaticResource Text3}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="CancelBtn_Click"
                            Content="Annuler"
                            Style="{StaticResource BtnCancel}" />
                        <Button
                            Click="OpenBtn_Click"
                            Content="🔓 Ouvrir"
                            IsDefault="True"
                            Style="{StaticResource BtnPrimary}" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>