<Window
    x:Class="VaultIQ.WPF.Views.EntryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VaultIQ — Entrée"
    Width="660"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Midnight" Color="#070E1C" />
        <SolidColorBrush x:Key="Mid" Color="#132944" />
        <SolidColorBrush x:Key="Panel" Color="#0F2035" />
        <SolidColorBrush x:Key="Blue" Color="#185FA5" />
        <SolidColorBrush x:Key="Accent" Color="#378ADD" />
        <SolidColorBrush x:Key="Teal2" Color="#12D68C" />
        <SolidColorBrush x:Key="Border1" Color="#26378ADD" />
        <SolidColorBrush x:Key="Border2" Color="#47378ADD" />
        <SolidColorBrush x:Key="Text1" Color="#D4E4F7" />
        <SolidColorBrush x:Key="Text2" Color="#7BA3C8" />
        <SolidColorBrush x:Key="Text3" Color="#3D6080" />
        <SolidColorBrush x:Key="Green" Color="#22C55E" />
        <SolidColorBrush x:Key="Amber" Color="#F59E0B" />
        <SolidColorBrush x:Key="Red" Color="#EF4444" />

        <!--  ── Shared input style ─────────────────────────────  -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Multi-line notes TextBox  -->
        <Style
            x:Key="FormTextArea"
            BasedOn="{StaticResource FormInput}"
            TargetType="TextBox">
            <Setter Property="Height" Value="70" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <!--  PasswordBox  -->
        <Style x:Key="FormPasswordInput" TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,0,36,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Field label  -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Text3}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!--  Small icon button (eye / copy / generate)  -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{StaticResource Mid}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Button cancel  -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A378ADD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource BtnCancel}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E72BB" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ── FormComboBox — même style que FormInput ───────────  -->
        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text1}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border
                            x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <Grid>
                                <!--  Flèche personnalisée  -->
                                <Path
                                    x:Name="Arrow"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Data="M 0 0 L 5 5 L 10 0"
                                    Fill="Transparent"
                                    IsHitTestVisible="False"
                                    Stroke="#47378ADD"
                                    StrokeThickness="1.5" />
                                <!--  Texte sélectionné  -->
                                <ContentPresenter
                                    x:Name="ContentSite"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    IsHitTestVisible="False" />
                                <!--  Zone cliquable invisible  -->
                                <ToggleButton
                                    x:Name="ToggleButton"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ClickMode="Press"
                                    Focusable="False"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <!--  Popup liste déroulante  -->
                                <Popup
                                    x:Name="Popup"
                                    AllowsTransparency="True"
                                    Focusable="False"
                                    IsOpen="{TemplateBinding IsDropDownOpen}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                    <Border
                                        x:Name="DropDownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200"
                                        Background="#0F2035"
                                        BorderBrush="#47378ADD"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="20"
                                                Opacity="0.6"
                                                ShadowDepth="4"
                                                Color="#000000" />
                                        </Border.Effect>
                                        <ScrollViewer Margin="2">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#47378ADD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!--  Style des items dans la liste  -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{StaticResource Text2}" />
                        <Setter Property="Padding" Value="10,6" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border
                                        x:Name="ItemBorder"
                                        Margin="2,1"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1E378ADD" />
                                            <Setter Property="Foreground" Value="{StaticResource Text1}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2E378ADD" />
                                            <Setter Property="Foreground" Value="{StaticResource Accent}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="{StaticResource Midnight}"
        BorderBrush="{StaticResource Border2}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="60"
                Opacity="0.8"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  body  -->
                <RowDefinition Height="Auto" />
                <!--  buttons  -->
            </Grid.RowDefinitions>

            <!--  ══ HEADER ══════════════════════════════════════  -->
            <Border
                Grid.Row="0"
                Padding="18,14"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#185FA5" />
                        <GradientStop Offset="1" Color="#0C3360" />
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock
                            x:Name="DialogTitle"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="✏️ Modifier l'entrée" />
                        <TextBlock
                            x:Name="DialogSubtitle"
                            Margin="0,3,0,0"
                            FontSize="11"
                            Foreground="#8CFFFFFF" />
                    </StackPanel>
                    <!--  Favorite toggle — image star  -->
                    <ToggleButton
                        x:Name="FavoriteToggle"
                        Width="32"
                        Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Checked="FavoriteToggle_Changed"
                        Cursor="Hand"
                        DockPanel.Dock="Right"
                        ToolTip="Marquer comme favori"
                        Unchecked="FavoriteToggle_Changed">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border
                                    Padding="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                    <Image
                                        x:Name="StarImg"
                                        Width="18"
                                        Height="18"
                                        Opacity="0.55"
                                        Source="/Resources/Icons/star_empty_18.png" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="StarImg" Property="Source" Value="/Resources/Icons/star_18.png" />
                                        <Setter TargetName="StarImg" Property="Opacity" Value="1" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                        <Setter TargetName="StarImg" Property="Opacity" Value="0.85" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </DockPanel>
            </Border>

            <!--  ══ BODY — 2 columns ═════════════════════════════  -->
            <Grid Grid.Row="1" Margin="18,16,18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  ── LEFT COLUMN ───────────────────────────────  -->
                <StackPanel Grid.Column="0">

                    <!--  Title  -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="TITRE" />
                        <Grid>
                            <TextBox
                                x:Name="TitleBox"
                                Style="{StaticResource FormInput}"
                                Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="11,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource Text3}"
                                IsHitTestVisible="False"
                                Text="Ex: CIC — Compte courant">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TitleBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!--  Username  -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="IDENTIFIANT / EMAIL" />
                        <DockPanel>
                            <Button
                                Margin="4,0,0,0"
                                Click="CopyUsernameBtn_Click"
                                Content="📋"
                                DockPanel.Dock="Right"
                                Style="{StaticResource IconBtn}"
                                ToolTip="Copier l'identifiant" />
                            <Grid>
                                <TextBox
                                    x:Name="UsernameBox"
                                    Style="{StaticResource FormInput}"
                                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="11,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{StaticResource Text3}"
                                    IsHitTestVisible="False"
                                    Text="Ex: jean@gmail.com">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=UsernameBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </StackPanel>

                    <!--  Password  -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="MOT DE PASSE" />
                        <DockPanel>
                            <StackPanel
                                Margin="4,0,0,0"
                                DockPanel.Dock="Right"
                                Orientation="Horizontal">
                                <Button
                                    x:Name="EyeBtn"
                                    Margin="0,0,4,0"
                                    Click="EyeBtn_Click"
                                    Content="👁"
                                    Style="{StaticResource IconBtn}"
                                    ToolTip="Afficher / Masquer" />
                                <Button
                                    Margin="0,0,4,0"
                                    Click="CopyPasswordBtn_Click"
                                    Content="📋"
                                    Style="{StaticResource IconBtn}"
                                    ToolTip="Copier le mot de passe" />
                                <Button
                                    Click="GenerateBtn_Click"
                                    Content="🎲"
                                    Style="{StaticResource IconBtn}"
                                    ToolTip="Générer un mot de passe" />
                            </StackPanel>
                            <Grid>
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    Padding="10,0"
                                    PasswordChanged="PasswordBox_PasswordChanged"
                                    Style="{StaticResource FormPasswordInput}" />
                                <TextBox
                                    x:Name="PasswordClearBox"
                                    FontFamily="Consolas"
                                    Style="{StaticResource FormInput}"
                                    TextChanged="PasswordClearBox_TextChanged"
                                    Visibility="Collapsed" />
                            </Grid>
                        </DockPanel>
                        <!--  Strength bar  -->
                        <Grid
                            x:Name="StrengthContainer"
                            Height="4"
                            Margin="0,5,0,0">
                            <Border Background="{StaticResource Panel}" CornerRadius="2" />
                            <Border
                                x:Name="StrengthFill"
                                Width="0"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Green}"
                                CornerRadius="2" />
                        </Grid>
                        <DockPanel Margin="0,3,0,0">
                            <TextBlock
                                x:Name="StrengthLabel"
                                FontSize="10"
                                Foreground="{StaticResource Green}" />
                            <TextBlock
                                x:Name="StrengthScore"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontSize="10"
                                Foreground="{StaticResource Text3}" />
                        </DockPanel>
                    </StackPanel>

                    <!--  URL  -->
                    <StackPanel Margin="0,6,0,12">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="URL" />
                        <DockPanel>
                            <Button
                                Margin="4,0,0,0"
                                Click="OpenUrlBtn_Click"
                                Content="🌐"
                                DockPanel.Dock="Right"
                                Style="{StaticResource IconBtn}"
                                ToolTip="Ouvrir dans le navigateur" />
                            <Grid>
                                <TextBox
                                    x:Name="UrlBox"
                                    Style="{StaticResource FormInput}"
                                    Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="11,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{StaticResource Text3}"
                                    IsHitTestVisible="False"
                                    Text="https://…">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=UrlBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </StackPanel>

                    <!--  Group  -->
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="GROUPE" />
                        <ComboBox
                            x:Name="GroupCombo"
                            SelectionChanged="GroupCombo_SelectionChanged"
                            Style="{StaticResource FormComboBox}" />
                    </StackPanel>

                </StackPanel>

                <!--  ── RIGHT COLUMN ──────────────────────────────  -->
                <StackPanel Grid.Column="2">

                    <!--  Notes  -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="NOTES" />
                        <Grid>
                            <TextBox
                                x:Name="NotesBox"
                                Style="{StaticResource FormTextArea}"
                                Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="11,9,0,0"
                                VerticalAlignment="Top"
                                FontSize="12"
                                Foreground="{StaticResource Text3}"
                                IsHitTestVisible="False"
                                Text="Notes libres, informations supplémentaires…">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=NotesBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!--  ── Integrated generator panel ───────────  -->
                    <Border
                        x:Name="GeneratorPanel"
                        Padding="12"
                        Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <StackPanel>
                            <!--  Panel header  -->
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="9"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource Text3}"
                                    Text="GÉNÉRATEUR INTÉGRÉ" />
                                <Button
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="CloseGeneratorPanel_Click"
                                    Content="✕"
                                    Cursor="Hand"
                                    DockPanel.Dock="Right"
                                    FontSize="11"
                                    Foreground="{StaticResource Text3}" />
                            </DockPanel>

                            <!--  Length slider  -->
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock
                                    Width="60"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    FontSize="11"
                                    Foreground="{StaticResource Text2}"
                                    Text="Longueur" />
                                <TextBlock
                                    x:Name="GenLengthValue"
                                    Width="28"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Foreground="{StaticResource Accent}"
                                    Text="20"
                                    TextAlignment="Right" />
                                <Slider
                                    x:Name="GenLengthSlider"
                                    Foreground="{StaticResource Accent}"
                                    IsSnapToTickEnabled="True"
                                    Maximum="64"
                                    Minimum="8"
                                    TickFrequency="1"
                                    Value="20" />
                            </DockPanel>

                            <!--  Checkboxes options  -->
                            <UniformGrid
                                Margin="0,0,0,10"
                                Columns="2"
                                Rows="2">
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkUppercase"
                                        Margin="0,0,6,0"
                                        IsChecked="True" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="Majuscules A–Z" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkLowercase"
                                        Margin="0,0,6,0"
                                        IsChecked="True" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="Minuscules a–z" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkDigits"
                                        Margin="0,0,6,0"
                                        IsChecked="True" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="Chiffres 0–9" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="ChkSymbols"
                                        Margin="0,0,6,0"
                                        IsChecked="False" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource Text3}"
                                        Text="Symboles !@#…" />
                                </StackPanel>
                            </UniformGrid>

                            <!--  No ambiguous  -->
                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                <CheckBox
                                    x:Name="ChkNoAmbiguous"
                                    Margin="0,0,6,0"
                                    IsChecked="True" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{StaticResource Text3}"
                                    Text="Exclure caractères ambigus (0, O, 1, l, I)" />
                            </StackPanel>

                            <!--  Preview  -->
                            <Border
                                Margin="0,0,0,8"
                                Padding="8,6"
                                Background="{StaticResource Mid}"
                                BorderBrush="{StaticResource Border1}"
                                BorderThickness="1"
                                CornerRadius="5">
                                <DockPanel>
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Click="RegenerateBtn_Click"
                                        Content="↻"
                                        DockPanel.Dock="Right"
                                        FontSize="14"
                                        Style="{StaticResource IconBtn}"
                                        ToolTip="Régénérer" />
                                    <TextBlock
                                        x:Name="GenPreview"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="{StaticResource Accent}"
                                        TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>

                            <!--  Entropy + use button  -->
                            <DockPanel>
                                <TextBlock
                                    x:Name="GenEntropyLabel"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    FontSize="10"
                                    Foreground="{StaticResource Text3}" />
                                <Button
                                    Height="28"
                                    Padding="12,0"
                                    Click="UseGeneratedBtn_Click"
                                    Content="✓ Utiliser"
                                    DockPanel.Dock="Right"
                                    FontSize="11"
                                    Style="{StaticResource BtnPrimary}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!--  Metadata (edit mode only)  -->
                    <Border
                        x:Name="MetaPanel"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="9"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Text3}"
                                Text="MÉTADONNÉES" />
                            <DockPanel Margin="0,0,0,3">
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="10"
                                    Foreground="{StaticResource Text3}"
                                    Text="Créé le" />
                                <TextBlock
                                    x:Name="MetaCreated"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    Foreground="{StaticResource Text2}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="10"
                                    Foreground="{StaticResource Text3}"
                                    Text="Modifié le" />
                                <TextBlock
                                    x:Name="MetaModified"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    Foreground="{StaticResource Text2}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!--  ══ BUTTONS ══════════════════════════════════════  -->
            <Border
                Grid.Row="2"
                Padding="18,12"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border1}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="False">
                    <!--  Strength summary left  -->
                    <TextBlock
                        x:Name="FooterStrength"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontSize="11"
                        Foreground="{StaticResource Text3}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Click="CancelBtn_Click"
                            Content="Annuler"
                            Style="{StaticResource BtnCancel}" />
                        <Button
                            x:Name="SaveBtn"
                            Click="SaveBtn_Click"
                            Content="💾 Enregistrer"
                            IsDefault="True"
                            Style="{StaticResource BtnPrimary}" />
                    </StackPanel>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
